APP_NAME=MillionaireGame
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database-storage/database.sqlite

JWT_SECRET=

# Origin allowed to call this API — the frontend container's published URL
FRONTEND_URL=http://localhost:8081

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
